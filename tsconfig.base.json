{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["./apps/frontend/src/*"]
    }
  }
}