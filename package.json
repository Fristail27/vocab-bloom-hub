{
  "name": "vocab-bloom-hub",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "description": "A modular open-source platform for working with vocabulary data: APIs, datasets, and tooling.",
  "homepage": "https://github.com/Fristail27/vocab-bloom-hub",
  "author": {
    "name": "Alexey Ryzhov (Fristail27)",
    "url": "https://github.com/Fristail27"
  },
  "bugs": {
    "url": "https://github.com/Fristail27/vocab-bloom-hub/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fristail27/vocab-bloom-hub.git"
  },
  "keywords": [
    "dictionary",
    "language",
    "linguistics",
    "nlp",
    "lexicon",
    "vocabulary",
    "thesaurus",
    "semantic-network",
    "multilingual",
    "translation",
    "etymology",
    "synonyms",
    "definitions",
    "language-learning",
    "natural-language-processing",
    "open-source",
    "typescript",
    "vocab-bloom-hub",
    "vocab-bloom"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "front:dev": "yarn workspace frontend dev",
    "server:dev": "yarn workspace server start:dev",
    "dev": "concurrently \"yarn server:dev\" \"yarn front:dev\"",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "yarn lint && yarn format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/jest": "^29.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=24",
    "yarn": ">=1.22.22"
  }
}
